<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Восстановление пароля</title>
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="/img/logo-icon.jpg">
</head>

<body>
    <%- include('partials/header', { hideBanner: true }) %>

        <main>
            <div class="auth-reg">
                <div class="auth-reg-info">
                    <form action="/forgot-password" method="POST" class="auth-reg-form">
                        <p class="auth-zag">Восстановление пароля</p>

                        <% if (error) { %>
                            <p style="color: #DAA655; text-align: center; margin-bottom: 15px;">
                                <%= error %>
                            </p>
                            <% } %>

                                <% if (success) { %>
                                    <p style="color: #4caf50; text-align: center; margin-bottom: 15px;">
                                        <%= success %>
                                    </p>
                                    <% } %>

                                        <div class="auth-inputs">
                                            <input type="email" name="email" class="auth-field"
                                                placeholder="Введите ваш email" required>
                                        </div>

                                        <button type="submit" class="auth-button">
                                            <p>Отправить код</p>
                                        </button>

                                        <a href="/login" class="no-acc">Вернуться ко входу</a>
                    </form>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>