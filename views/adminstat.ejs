<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Админ-панель - Статистика</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" href="/img/logo-icon.jpg">
</head>

<body>
    <%- include('partials/header') %>

        <main>
            <div class="adminstat">
                <div class="admin-left">
    <div class="admin-menu-item <%= adminPage === 'statistics' ? 'active' : '' %>" id="navStatistics">
        <p>Статистика</p>
    </div>
    <div class="admin-menu-item <%= adminPage === 'users' ? 'active' : '' %>" id="navUsers">
        <p>Пользователи</p>
    </div>
    <div class="admin-menu-item">
        <p>Мероприятия</p>
    </div>
    <div class="admin-submenu">
        <p class="admin-m-txt <%= adminPage === 'events' ? 'admin-m-txt-active' : '' %>" id="navEventsManage">Управление</p>
        <p class="admin-m-txt <%= adminPage === 'events-stats' ? 'admin-m-txt-active' : '' %>" id="navEventsStats">Статистика</p>
    </div>
    <div class="admin-menu-item <%= adminPage === 'sotrud' ? 'active' : '' %>" id="navSotrud">
        <p>Сотрудничество</p>
    </div>
    <div class="admin-menu-item <%= adminPage === 'about' ? 'active' : '' %>" id="navAbout">
    <p>О нас</p>
</div>
</div>
                <div class="admin-right">
                    <div class="admin-r-blocks">
    <div class="admin-r-block">
        <p class="a-r-b-number">
            <%= totalUsers %>
        </p>
        <p class="a-r-b-name">Пользователи</p>
    </div>
    <div class="admin-r-block">
        <p class="a-r-b-number">
            <%= activeUsers %>
        </p>
        <p class="a-r-b-name">Активно</p>
    </div>
    <div class="admin-r-block">
        <p class="a-r-b-number">
            <%= totalEvents %>
        </p>
        <p class="a-r-b-name">Мероприятия</p>
    </div>
    <div class="admin-r-block">
        <p class="a-r-b-number">
            <%= totalApplications %>
        </p>
        <p class="a-r-b-name">Заявки</p>
    </div>
</div>
                    <div class="last-acts">
                        <p>Последние действия</p>
                        <input type="text" id="searchInput" placeholder="Поиск по действию...">
                        <div class="log" id="logContainer">
                            <div class="log-header">
                                <div>Дата</div>
                                <div>Действие</div>
                                <div>Пользователь</div>
                            </div>
                            <div id="logsList"></div>
                        </div>
                        <div class="pagination" id="pagination" style="display: none;">
                            <button class="page-btn" id="prevPage">&laquo; Назад</button>
                            <span class="page-info">Страница <span id="currentPage">1</span> из <span id="totalPages">1</span></span>
                            <button class="page-btn" id="nextPage">Вперед &raquo;</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <script>
            let allLogs = [];
            let filteredLogs = [];
            let currentPage = 1;
            let itemsPerPage = 10;
            let searchQuery = '';

            const logsList = document.getElementById('logsList');
            const searchInput = document.getElementById('searchInput');
            const paginationDiv = document.getElementById('pagination');
            const prevBtn = document.getElementById('prevPage');
            const nextBtn = document.getElementById('nextPage');
            const currentPageSpan = document.getElementById('currentPage');
            const totalPagesSpan = document.getElementById('totalPages');

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            async function loadAllLogs() {
                if (logsList) {
                    logsList.innerHTML = '<div class="log-row" style="justify-content: center;">Загрузка...</div>';
                }

                try {
                    const res = await fetch('/admin/api/logs?page=1&limit=10000');
                    const data = await res.json();

                    if (data.success) {
                        allLogs = data.logs;
                        applySearch();
                    } else {
                        logsList.innerHTML = '<div class="log-row" style="justify-content: center;">Ошибка загрузки</div>';
                    }
                } catch (error) {
                    console.error('Ошибка загрузки:', error);
                    logsList.innerHTML = '<div class="log-row" style="justify-content: center;">Ошибка загрузки</div>';
                }
            }

            function applySearch() {
    if (!searchQuery || searchQuery.trim() === '') {
        filteredLogs = [...allLogs];
    } else {
        const query = searchQuery.toLowerCase().trim();
        filteredLogs = allLogs.filter(log => {
            return log.action.toLowerCase().includes(query) || 
                   log.user_name.toLowerCase().includes(query);
        });
    }
    currentPage = 1;
    renderPaginatedLogs();
}

            function renderPaginatedLogs() {
                const totalItems = filteredLogs.length;
                const totalPagesCount = Math.ceil(totalItems / itemsPerPage);
                const start = (currentPage - 1) * itemsPerPage;
                const end = start + itemsPerPage;
                const pageLogs = filteredLogs.slice(start, end);

                if (totalPagesSpan) totalPagesSpan.textContent = totalPagesCount;
                if (currentPageSpan) currentPageSpan.textContent = currentPage;

                if (paginationDiv) {
                    paginationDiv.style.display = totalPagesCount > 1 ? 'flex' : 'none';
                }
                if (prevBtn) prevBtn.disabled = currentPage <= 1;
                if (nextBtn) nextBtn.disabled = currentPage >= totalPagesCount;

                renderLogs(pageLogs);
            }

            function renderLogs(logs) {
                if (!logsList) return;

                if (logs.length === 0) {
                    logsList.innerHTML = `<div class="log-row" style="justify-content: center; text-align: center;">
                        <div colspan="3">${searchQuery ? 'Ничего не найдено' : 'Нет действий'}</div>
                    </div>`;
                    return;
                }

                logsList.innerHTML = logs.map(log => `
                    <div class="log-row">
                        <div>${escapeHtml(log.created_at)}</div>
                        <div>${escapeHtml(log.action)}</div>
                        <div>${escapeHtml(log.user_name)}</div>
                    </div>
                `).join('');
            }

            function goToPage(page) {
    const totalPagesCount = Math.ceil(filteredLogs.length / itemsPerPage);
    if (page < 1 || page > totalPagesCount) return;
    currentPage = page;
    renderPaginatedLogs();
    
    // Скроллим к началу блока с логами, а не куда-то в середину
    const logsHeader = document.querySelector('.log-header');
    if (logsHeader) {
        const rect = logsHeader.getBoundingClientRect();
        const scrollTop = window.pageYOffset + rect.top - 100;
        window.scrollTo({ top: scrollTop, behavior: 'smooth' });
    }
}

            let searchTimeout;
            if (searchInput) {
                searchInput.addEventListener('input', function (e) {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchQuery = e.target.value;
                        applySearch();
                    }, 300);
                });
            }

            if (prevBtn) {
                prevBtn.onclick = () => goToPage(currentPage - 1);
            }
            if (nextBtn) {
                nextBtn.onclick = () => goToPage(currentPage + 1);
            }

            document.getElementById('navStatistics').onclick = () => window.location.href = '/admin/statistics';
            document.getElementById('navUsers').onclick = () => window.location.href = '/admin/users';
            document.getElementById('navEventsManage').onclick = () => window.location.href = '/admin/events';
            document.getElementById('navEventsStats').onclick = () => window.location.href = '/admin/events-stats';
document.getElementById('navSotrud').onclick = () => window.location.href = '/admin/sotrud';
document.getElementById('navAbout').onclick = () => window.location.href = '/admin/about';
            loadAllLogs();
        </script>

        <script>
    // Админ-панель бургер-меню (только для мобильных)
    document.addEventListener('DOMContentLoaded', function() {
        const adminLeft = document.querySelector('.admin-left');
        if (adminLeft && window.innerWidth <= 768) {
            // Добавляем класс для мобильной версии
            adminLeft.classList.add('admin-left-mobile');
            
            // Добавляем бургер в админку, если его нет
            const adminStat = document.querySelector('.adminstat');
            if (adminStat && !document.querySelector('.admin-burger')) {
                const burgerHtml = `
                    <div class="admin-burger">
                        <span class="admin-burger-title">Меню</span>
                        <div class="admin-burger-btn">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                    <div class="admin-menu-overlay"></div>
                `;
                adminStat.insertAdjacentHTML('afterbegin', burgerHtml);
                
                const burgerBtn = document.querySelector('.admin-burger-btn');
                const overlay = document.querySelector('.admin-menu-overlay');
                
                function toggleAdminMenu() {
                    adminLeft.classList.toggle('active');
                    burgerBtn.classList.toggle('active');
                    overlay.classList.toggle('active');
                    if (adminLeft.classList.contains('active')) {
                        document.body.style.overflow = 'hidden';
                    } else {
                        document.body.style.overflow = '';
                    }
                }
                
                if (burgerBtn) {
                    burgerBtn.addEventListener('click', function(e) {
                        e.stopPropagation();
                        toggleAdminMenu();
                    });
                }
                
                if (overlay) {
                    overlay.addEventListener('click', toggleAdminMenu);
                }
                
                // Закрытие при клике на пункты меню
                document.querySelectorAll('.admin-left .admin-menu-item, .admin-left .admin-m-txt').forEach(item => {
                    item.addEventListener('click', () => {
                        if (window.innerWidth <= 768) {
                            toggleAdminMenu();
                        }
                    });
                });
            }
        }
    });

    // Адаптация при изменении размера окна
    window.addEventListener('resize', function() {
        const nav = document.querySelector('.nav');
        const burger = document.querySelector('.burger-menu');
        const adminLeft = document.querySelector('.admin-left');
        const overlay = document.querySelector('.admin-menu-overlay');
        const burgerBtn = document.querySelector('.admin-burger-btn');
        
        if (window.innerWidth > 768) {
            if (nav) nav.classList.remove('active');
            if (burger) burger.classList.remove('active');
            if (adminLeft) {
                adminLeft.classList.remove('active');
                // Убираем мобильные стили
                adminLeft.style.left = '';
                adminLeft.style.position = '';
            }
            if (overlay) overlay.classList.remove('active');
            if (burgerBtn) burgerBtn.classList.remove('active');
            document.body.style.overflow = '';
        } else {
            // Для мобильных - восстанавливаем
            if (adminLeft) {
                adminLeft.style.left = '';
                adminLeft.style.position = 'fixed';
            }
        }
    });

    // Бургер-меню для обычной навигации
document.addEventListener('DOMContentLoaded', function() {
    const burgerMenu = document.querySelector('.burger-menu');
    const navMenu = document.querySelector('.nav');
    
    // Создаем оверлей
    let overlay = document.querySelector('.nav-overlay');
    if (!overlay) {
        overlay = document.createElement('div');
        overlay.className = 'nav-overlay';
        document.body.appendChild(overlay);
    }
    
    function closeMenu() {
        burgerMenu.classList.remove('active');
        navMenu.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
    }
    
    function openMenu() {
        burgerMenu.classList.add('active');
        navMenu.classList.add('active');
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
    }
    
    if (burgerMenu && navMenu) {
        burgerMenu.addEventListener('click', function(e) {
            e.stopPropagation();
            if (navMenu.classList.contains('active')) {
                closeMenu();
            } else {
                openMenu();
            }
        });
        
        // Закрытие по клику на оверлей
        overlay.addEventListener('click', closeMenu);
        
        // Закрытие при клике на ссылку
        document.querySelectorAll('.nav a').forEach(link => {
            link.addEventListener('click', closeMenu);
        });
    }
});
</script>
</body>

</html>