                            <p class="mvm-r-t-t-opis">${escapeHtml(event.event_type)}</p>
                        </div>
                        <div class="mvm-r-t-b">
                            <p class="mvm-r-t-t-opis"><span>Куратор:</span> ${escapeHtml(event.curator || '—')}</p>
                            <p class="mvm-r-t-t-opis">${formattedDate} <span>${event.time}</span></p>
                        </div>
                    </div>
                    <div class="mwm-txt">
                        <p>${escapeHtml(event.description || 'Описание отсутствует').replace(/\n/g, '<br>')}</p>
                    </div>
                    <div class="mwm-r-b">
                        <hr class="mvm-line">
                        <div class="mvm-underline">
                            <div class="tick-cost">
                                <div class="t-c">
                                    <p class="t-c-name">Осталось мест</p>
                                    <p class="t-c-opis">${event.available_seats} из ${event.total_seats}</p>
                                </div>
                                <div class="t-c">
                                    <p class="t-c-name">Стоимость</p>
                                    <p class="t-c-opis">${event.price}₽</p>
                                </div>
                            </div>
                            <button class="mvm-btn" disabled style="opacity: 0.5; cursor: not-allowed; background-color: #aaa;">Хочу пойти</button>
                        </div>
                    </div>
                `;

                const modal = document.getElementById('eventModal');
                modal.classList.remove('closing');
                modal.classList.add('show');
                document.body.style.overflow = 'hidden';
            }

            function closeEventModal() {
                const modal = document.getElementById('eventModal');
                if (modal) {
                    modal.classList.add('closing');
                    setTimeout(() => {
                        modal.classList.remove('show', 'closing');
                        document.body.style.overflow = '';
                    }, 300);
                }
            }

            function openDeleteConfirmModal(eventCode) {
    const event = allEvents.find(e => String(e.event_code) === String(eventCode));
    if (!event) return;
    
    eventToDelete = eventCode;
    
    // Проверяем, есть ли купленные билеты
    const hasTickets = (event.total_seats - event.available_seats) > 0;
    const ticketsSold = event.total_seats - event.available_seats;
    
    const modal = document.getElementById('deleteConfirmModal');
    const messageElement = document.getElementById('deleteConfirmMessage');
    
    if (hasTickets) {
        messageElement.innerHTML = `⚠️ ВНИМАНИЕ! На это мероприятие продано ${ticketsSold} билетов.<br><br>
        При удалении мероприятия:<br>
        • Все билеты будут аннулированы<br>
        • Пользователям придут уведомления<br>
        • Средства будут возвращены на карты в течение суток<br><br>
        Вы уверены, что хотите удалить мероприятие?`;
    } else {
        messageElement.innerHTML = `Вы уверены, что хотите удалить мероприятие "${event.title_short}"?<br><br>
        Это действие нельзя отменить.`;
    }
    
    modal.classList.remove('closing');
    modal.classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeDeleteConfirmModal() {
    const modal = document.getElementById('deleteConfirmModal');
    if (modal) {
        modal.classList.add('closing');
        setTimeout(() => {
            modal.classList.remove('show', 'closing');
            document.body.style.overflow = '';
        }, 300);
    }
    eventToDelete = null;
}

            function closeDeleteConfirmModal() {
                const modal = document.getElementById('deleteConfirmModal');
                if (modal) {
                    modal.classList.add('closing');
                    setTimeout(() => {
                        modal.classList.remove('show', 'closing');
                        document.body.style.overflow = '';
                    }, 300);
                }
                eventToDelete = null;
            }

            // В функции confirmDeleteEvent обновите сообщение об успехе
async function confirmDeleteEvent() {
    if (!eventToDelete) return;
    
    const confirmBtn = document.querySelector('#deleteConfirmModal .confirm-delete-btn');
    const originalText = confirmBtn?.textContent;
    
    if (confirmBtn) {
        confirmBtn.textContent = 'Удаление...';
        confirmBtn.disabled = true;
    }
    
    try {
        const res = await fetch(`/api/events/${eventToDelete}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        
        if (data.success) {
            let message = '';
            if (data.ticketsReturned > 0) {
                message = `✅ Мероприятие удалено! Возвращено ${data.ticketsReturned} билет(ов). Уведомления отправлены ${data.usersNotified} пользователям.`;
            } else {
                message = `✅ Мероприятие удалено!`;
            }
            showToastRight(message, 'success');
            closeDeleteConfirmModal();
            loadEvents(); // Перезагружаем список
        } else {
            showToastRight(data.message || 'Ошибка при удалении', 'error');
            closeDeleteConfirmModal();
        }
    } catch (error) {
        console.error('Ошибка удаления:', error);
        showToastRight('Ошибка сервера: ' + error.message, 'error');
        closeDeleteConfirmModal();
    } finally {
        if (confirmBtn) {
            confirmBtn.textContent = originalText;
            confirmBtn.disabled = false;
        }
    }
}

