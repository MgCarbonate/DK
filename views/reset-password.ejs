<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Сброс пароля</title>
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="/img/logo-icon.jpg">
</head>

<body>
    <%- include('partials/header', { hideBanner: true }) %>

        <main>
            <div class="auth-reg">
                <div class="auth-reg-info">
                    <form action="/reset-password" method="POST" class="auth-reg-form">
                        <p class="auth-zag">Сброс пароля</p>

                        <% if (error) { %>
                            <p style="color: #DAA655; text-align: center; margin-bottom: 15px;">
                                <%= error %>
                            </p>
                            <% } %>

                                <p style="color: white; text-align: center; margin-bottom: 15px; font-size: 14px;">
                                    Код отправлен на <strong>
                                        <%= email %>
                                    </strong>
                                </p>

                                <div class="auth-inputs">
                                    <input type="text" name="code" class="auth-field" placeholder="Код из письма"
                                        maxlength="6" required>
                                    <input type="password" name="new_password" class="auth-field"
                                        placeholder="Новый пароль" required>
                                    <input type="password" name="confirm_password" class="auth-field"
                                        placeholder="Подтверждение пароля" required>
                                </div>

                                <button type="submit" class="auth-button">
                                    <p>Сбросить пароль</p>
                                </button>

                                <a href="/login" class="no-acc">Вернуться ко входу</a>
                    </form>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>